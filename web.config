<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Default document -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
            </files>
        </defaultDocument>

        <!-- Static content MIME types -->
        <staticContent>
            <remove fileExtension=".woff" />
            <remove fileExtension=".woff2" />
            <mimeMap fileExtension=".woff" mimeType="font/woff" />
            <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
        </staticContent>

        <!-- Security: block direct access to sensitive files -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="config.php" />
                    <add segment="includes" />
                    <add segment=".windsurf" />
                    <add segment="sql" />
                </hiddenSegments>
                <fileExtensions>
                    <add fileExtension=".sql" allowed="false" />
                </fileExtensions>
                <!-- Allow large file uploads -->
                <requestLimits maxAllowedContentLength="104857600" />
            </requestFiltering>
        </security>

        <!-- Headers for embed support -->
        <httpProtocol>
            <customHeaders>
                <remove name="X-Frame-Options" />
                <add name="X-Content-Type-Options" value="nosniff" />
            </customHeaders>
        </httpProtocol>

        <!-- URL Rewrite (optional, for clean URLs in future) -->
        <!--
        <rewrite>
            <rules>
                <rule name="Flipbook Viewer" stopProcessing="true">
                    <match url="^view/([a-zA-Z0-9-]+)$" />
                    <action type="Rewrite" url="viewer.php?slug={R:1}" />
                </rule>
            </rules>
        </rewrite>
        -->
    </system.webServer>
</configuration>
